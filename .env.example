# Redis & Task Queue
REDIS_URL="redis://localhost:6379/0"

# Security & Authentication
# Generate using: openssl rand -hex 32
JWT_SECRET="09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
